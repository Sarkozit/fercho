{
  "name": "fercho-print-agent",
  "version": "1.0.0",
  "description": "Print Agent for Fercho POS - Epson TM-T20II thermal printer bridge",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:portable": "electron-builder --win --x64 -c.win.target=dir"
  },
  "build": {
    "appId": "co.caballoloco.fercho.print",
    "productName": "FerchoPrint",
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "files": [
      "main.js",
      "src/**/*",
      "assets/**/*"
    ],
    "extraResources": []
  },
  "dependencies": {
    "ws": "^8.16.0",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
